# Copy this file to .env
# cp .env.example .env

PORT=4000
NODE_ENV=development
JWT_SECRET=arthraksh-secret-change-in-production

# Required only for live weather data.
OPENWEATHER_API_KEY=

# Local non-Docker startup uses: uvicorn main:app --port 5001
# Docker Compose sets this internally to http://ml-service:5000
# Backend auto-falls back to local formulas if this is unreachable
ML_SERVICE_URL=http://localhost:5001

FRONTEND_URL=http://localhost:3000

# Public sandbox/demo payment keys used by the checkout UI.
RAZORPAY_TEST_KEY_ID=rzp_test_gigshield_demo
STRIPE_SANDBOX_PUBLISHABLE_KEY=pk_test_gigshield_demo

# Required for the AI assistant/chatbot.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Required only for real email delivery.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="ArthRaksh Alerts <alerts@example.com>"
SMTP_SECURE=false
SMTP_REQUIRE_TLS=false
SMTP_TIMEOUT_MS=15000
EMAIL_MAX_ATTEMPTS=5
