# Copy this file to .env
# cp .env.example .env

PORT=4000
NODE_ENV=development
JWT_SECRET=gigshield-secret-change-in-production

# Get a free key at openweathermap.org → API Keys tab
# Without this key the backend uses mock weather (everything still works)
OPENWEATHER_API_KEY=your_key_here

# Local non-Docker startup uses: uvicorn main:app --port 5001
# Docker Compose sets this internally to http://ml-service:5000
# Backend auto-falls back to local formulas if this is unreachable
ML_SERVICE_URL=http://localhost:5001

FRONTEND_URL=http://localhost:3000

# Mock gateway branding for demo checkout and instant payout rails
RAZORPAY_TEST_KEY_ID=rzp_test_gigshield_demo
STRIPE_SANDBOX_PUBLISHABLE_KEY=pk_test_gigshield_demo

# Groq chatbot
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Optional SMTP config for real email reminders and action updates
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASS=replace_me
SMTP_FROM="GigShield Alerts <alerts@example.com>"
SMTP_SECURE=false
SMTP_REQUIRE_TLS=false
SMTP_TIMEOUT_MS=15000
EMAIL_MAX_ATTEMPTS=5
