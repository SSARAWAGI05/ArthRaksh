# Copy to .env before running docker compose if you want to override defaults:
# cp .env.docker.example .env

JWT_SECRET=arthraksh-secret-change-in-production

# Required only for live weather data.
OPENWEATHER_API_KEY=

# Required for the AI assistant/chatbot.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Public sandbox/demo payment keys used by the checkout UI.
RAZORPAY_TEST_KEY_ID=rzp_test_gigshield_demo
STRIPE_SANDBOX_PUBLISHABLE_KEY=pk_test_gigshield_demo

# Required only for real email delivery.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="ArthRaksh Alerts <alerts@arthraksh.local>"
SMTP_SECURE=false
SMTP_REQUIRE_TLS=false
SMTP_TIMEOUT_MS=15000
EMAIL_MAX_ATTEMPTS=5
