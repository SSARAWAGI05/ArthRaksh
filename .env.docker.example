# Copy to .env before running docker compose if you want to override defaults:
# cp .env.docker.example .env

JWT_SECRET=gigshield-secret-change-in-production

# Optional live integrations. Leave blank for demo/mock behavior.
OPENWEATHER_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Demo payment public keys.
RAZORPAY_TEST_KEY_ID=rzp_test_gigshield_demo
STRIPE_SANDBOX_PUBLISHABLE_KEY=pk_test_gigshield_demo

# Optional SMTP settings. Leave blank to keep email delivery queued/mock-only.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="GigShield Alerts <alerts@gigshield.local>"
SMTP_SECURE=false
SMTP_REQUIRE_TLS=false
SMTP_TIMEOUT_MS=15000
EMAIL_MAX_ATTEMPTS=5
